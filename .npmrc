# ✅ 1. Mandatory DWP Nexus registry (primary source for ALL packages)
registry=https://registry.npmjs.org/
strict-ssl=true
ignore-scripts=true

# ✅ 2. Required for @dwp/* packages — must use GROUP-LEVEL registry
@dwp:registry=https://gitlab.com/api/v4/groups/dwp/-/packages/npm/
//gitlab.com/api/v4/groups/dwp/-/packages/npm/:_authToken=${CI_JOB_TOKEN}